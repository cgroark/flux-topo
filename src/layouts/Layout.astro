---
import {EnvelopeIcon, ListIcon, XIcon} from '@phosphor-icons/react';
import ImageCarousel from '../components/ImageCarousel'

export interface Props {
  title: string;
}

const title = 'Flux Topo | Rebuild your landspace';
const description = 'Flux Topo rebuilds your urban landsapce';
const heroContent = await import('../content/sections/hero.md');
const footerContent = await import('../content/sections/footer.md');
const contactContent = await import('../content/sections/contact.md');
const navContent = await import('../content/navigation/main.md');

const hero = heroContent.frontmatter;
const footer = footerContent.frontmatter;
const contact = contactContent.frontmatter;
const navigation = navContent.frontmatter;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
	    <title>{title}</title>
	    <meta name="description" content={description}>
	    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
   	<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&family=Roboto+Slab:wght@100..900&display=swap" rel="stylesheet">

    <!-- Add Netlify Identity Widget -->
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>

   	<!-- Navigation -->
    <nav class="main-nav">
      <div class="nav-container">
        <a href="/#hero" class="logo-nav">
          <img src={navigation.logo} />
        </a>

        <!-- Hamburger button -->
        <button class="nav-toggle" aria-label="Toggle navigation">
          <span class="icon icon-menu"><ListIcon  size={32} /></span>
          <span class="icon icon-close"><XIcon size={32} /></span>
        </button>

        <ul class="nav-links">
					{navigation.nav_items.map((item) => {

						return (
							<li>
								<a
									href={item.href}
									aria-label={item.label}
								>
									{item.label && <span>{item.label}</span>}
								</a>
							</li>
						);
					})}
				</ul>
      </div>
    </nav>

		<!-- Hero Section -->
		<section id="hero" class="hero-section section reveal">
			<div class="hero-shell">
				<div class="hero-copy">
					<h1>{hero.title}</h1>
					<h2>{hero.description}</h2>
					<div class="hero-actions" aria-label="Primary">
						<a href="/#about" class="hero-button primary">{hero.button_one}</a>
						<a href="/#contact" class="hero-button secondary">{hero.button_two}</a>
					</div>
				</div>

				<div class="hero-visual" aria-hidden="true">
					<div class="topo-panel">
						<span class="scan-line"></span>
						<span class="topo-line line-one"></span>
						<span class="topo-line line-two"></span>
						<span class="topo-line line-three"></span>
						<span class="topo-line line-four"></span>
						<div class="panel-footer">
							<span>{hero.title}</span>
							<span>001</span>
						</div>
					</div>
				</div>
			</div>
		</section>

    <!-- Page Content Rendered -->
    <slot />

    <!-- Contact Section -->
    <section id="contact" class="contact-section section reveal">
			<div class="contact-shell constrain">
				<div class="contact-copy">
					<h2>{contact.title}</h2>
					<p id="contact-text">{contact.textSection}</p>
				</div>

				<div class="contact-card">
					<div class="contact-card-content">
						<a class="contact-email" href={`mailto:${contact.email}`}>
							<EnvelopeIcon size={32} />
							<span>{contact.emailString}</span>
						</a>
					</div>

					<div class="contact-logo-mark">
						<img src={contact.logo} alt="" />
					</div>
				</div>
			</div>
    </section>

  	<!-- Footer Section -->
    <section id="footer" class="footer-section">
      <p>{footer.copyright}</p>
      <p>{footer.owner} <a href={footer.ownerLink} target="_blank">{footer.ownerSite}</a></p>
    </section>

    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", (user) => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });

        window.netlifyIdentity.on("confirm", () => {
          document.location.href = "/admin/";
        });

        window.netlifyIdentity.on("recovery", () => {
          document.location.href = "/admin/";
        });
      }

      // Fallback in case the identity widget isn't ready immediately
      window.addEventListener("load", () => {
        if (window.location.search.includes("confirmation_token") ||
            window.location.search.includes("recovery_token")) {
          document.location.href = "/admin/";
        }
      });
    </script>

    <script>
      (() => {
        const nav = document.querySelector('.main-nav');
        if (!nav) return;

        const navLinks = Array.from(nav.querySelectorAll('a[href]'));
        const sections = Array.from(document.querySelectorAll('section[id]'));
        if (!sections.length) return;

        const getHashFromHref = (href) => {
          if (!href) return '';
          if (href.startsWith('#')) return href;
          if (href.startsWith('/#')) return href.slice(1);

          try {
            const url = new URL(href, window.location.origin);
            return url.pathname === '/' ? url.hash : '';
          } catch {
            return '';
          }
        };

        const sectionIds = new Set(sections.map(section => section.id));
        const sectionLinks = navLinks.filter(link => {
          const hash = getHashFromHref(link.getAttribute('href'));
          return hash && sectionIds.has(hash.slice(1));
        });

        const clearActive = () => {
          navLinks.forEach(link => link.classList.remove('active'));
        };

        const updateActiveSection = () => {
          const activationLine = (nav.offsetHeight || 0) + 40;
          const current = sections.reduce((active, section) => {
            return section.getBoundingClientRect().top <= activationLine ? section : active;
          }, sections[0]);

          if (!current) return;

          clearActive();
          sectionLinks
            .filter(link => getHashFromHref(link.getAttribute('href')) === `#${current.id}`)
            .forEach(link => link.classList.add('active'));
        };

        updateActiveSection();
        window.addEventListener('scroll', updateActiveSection, { passive: true });
        window.addEventListener('resize', updateActiveSection);
        window.addEventListener('hashchange', updateActiveSection);
      })();
    </script>

    <script>
      (() => {
        const toggle = document.querySelector('.nav-toggle');
        const navLinks = document.querySelector('.nav-links');

        if (!toggle || !navLinks) return;

        const openMenu = () => {
          navLinks.classList.add('open');
          toggle.classList.add('open');
        };

        const closeMenu = () => {
          navLinks.classList.remove('open');
          toggle.classList.remove('open');
        };

        toggle.addEventListener('click', () => {
          navLinks.classList.contains('open') ? closeMenu() : openMenu();
        });

        // Close menu + reset icon when a link is clicked
        navLinks.querySelectorAll('a').forEach(link =>
          link.addEventListener('click', closeMenu)
        );
      })();
    </script>

    <script>
      (() => {
        const reveals = document.querySelectorAll('.reveal');

        if (!reveals.length) return;

        const observer = new IntersectionObserver((entries, obs) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              obs.unobserve(entry.target); // animate once
            }
          });
        }, {
          threshold: 0.15
        });

        reveals.forEach(el => observer.observe(el));
      })();
    </script>
  </body>
</html>

<style is:global>
	:root {
		--nav-height: 82px;
		--ink: #231f20;
		--paper: #f6f7f3;
		--cream: #f3efe6;
		--moss: #3A5736;
		--clay: #9f6849;
	}

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    margin: 0;
    padding: 0;
    font-size: 20px;
    line-height: 1.3;
  }

  h1, h2, h3 {
    font-family: "Fraunces", serif;
    font-optical-sizing: auto;
    font-weight: 400;
    font-style: normal;
  }

  body, p, a {
    font-family: "Roboto Slab", serif;
  	font-optical-sizing: auto;
    font-style: normal;
  }

	p {
		margin-bottom: 16px;
	}

	div > p:last-child {
		margin-bottom: 0;
	}

  body {
		background-color: var(--paper);
	}

	section.constrain {
		max-width: 1400px;
		margin: auto;
	}

	p, h1, li, h2, h3 {
		color: #f3efe6;
	}

	.flex-section-center {
		display: flex;
		justify-content: space-between;
		gap: 25px;
		align-items: start;
	}

	.flex-section-center.border .body-section-image {
		align-self: start;
	}

	h2 {
		font-size: clamp(24px, 4vw, 36px);
	}

	.body-section {
		padding: 70px 50px;
	}

	.section-kicker,
	.hero-kicker {
		width: fit-content;
		margin-bottom: 22px;
		padding: 8px 12px;
		color: var(--moss);
		background: rgba(243, 239, 230, 0.82);
		border: 1px solid rgba(35, 31, 32, 0.16);
		font-size: clamp(12px, 1.3vw, 15px);
		letter-spacing: 0;
		text-transform: uppercase;
	}

	.hero-section {
		position: relative;
		isolation: isolate;
		min-height: calc(100svh - var(--nav-height));
		margin-top: var(--nav-height);
		padding: clamp(56px, 8vw, 110px) 50px;
		display: flex;
		align-items: center;
		overflow: hidden;
		background:
			linear-gradient(90deg, rgba(246, 247, 243, 0.96), rgba(246, 247, 243, 0.72) 54%, rgba(35, 31, 32, 0.04)),
			repeating-linear-gradient(0deg, rgba(35, 31, 32, 0.055) 0 1px, transparent 1px 72px),
			repeating-linear-gradient(90deg, rgba(35, 31, 32, 0.045) 0 1px, transparent 1px 72px),
			var(--paper);
		border-bottom: 2px solid var(--ink);
	}

	.hero-section::before,
	.hero-section::after {
		content: '';
		position: absolute;
		inset: auto;
		z-index: -1;
		pointer-events: none;
	}

	.hero-section::before {
		width: min(52vw, 680px);
		height: min(52vw, 680px);
		right: -18vw;
		top: 8%;
		border: 1px solid rgba(58, 87, 54, 0.34);
		border-radius: 50%;
		box-shadow:
			inset 0 0 0 34px rgba(58, 87, 54, 0.035),
			inset 0 0 0 92px rgba(159, 104, 73, 0.04);
	}

	.hero-section::after {
		width: 46%;
		height: 2px;
		left: 50px;
		bottom: clamp(28px, 5vw, 64px);
		background: linear-gradient(90deg, var(--moss), rgba(159, 104, 73, 0.7), transparent);
	}

	.hero-shell {
		width: min(100%, 1400px);
		margin: 0 auto;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 0.68fr);
		align-items: center;
		gap: clamp(36px, 7vw, 112px);
	}

	.hero-copy {
		max-width: 790px;
	}

	.hero-kicker {
		margin-bottom: 22px;
	}

	.hero-section h1 {
		color: var(--ink);
		font-size: clamp(64px, 11vw, 154px);
		line-height: 0.88;
		max-width: 900px;
		margin-bottom: clamp(18px, 3vw, 30px);
	}

	.hero-section h2 {
		color: rgba(35, 31, 32, 0.78);
		font-family: "Roboto Slab", serif;
		font-size: clamp(20px, 2.4vw, 34px);
		font-weight: 300;
		line-height: 1.2;
		max-width: 680px;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: clamp(28px, 5vw, 52px);
	}

	.hero-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 48px;
		padding: 12px 18px;
		border: 1px solid var(--ink);
		color: var(--ink);
		text-decoration: none;
		font-size: 15px;
		transition:
			background-color 180ms ease,
			color 180ms ease,
			transform 180ms ease,
			box-shadow 180ms ease;
	}

	.hero-button:hover {
		transform: translateY(-2px);
		box-shadow: 5px 5px 0 rgba(35, 31, 32, 0.16);
	}

	.hero-button.primary {
		background: var(--ink);
		color: var(--cream);
	}

	.hero-button.secondary {
		background: rgba(243, 239, 230, 0.72);
	}

	.hero-visual {
		display: flex;
		justify-content: flex-end;
	}

	.topo-panel {
		position: relative;
		width: min(100%, 460px);
		aspect-ratio: 0.84;
		overflow: hidden;
		background:
			linear-gradient(145deg, rgba(35, 31, 32, 0.94), rgba(58, 87, 54, 0.94)),
			var(--ink);
		border: 2px solid var(--ink);
		box-shadow: 18px 18px 0 rgba(35, 31, 32, 0.1);
	}

	.topo-panel::before {
		content: '';
		position: absolute;
		inset: 22px;
		border: 1px solid rgba(243, 239, 230, 0.34);
	}

	.topo-panel::after {
		content: '';
		position: absolute;
		inset: 0;
		background:
			repeating-linear-gradient(0deg, rgba(243, 239, 230, 0.08) 0 1px, transparent 1px 30px),
			repeating-linear-gradient(90deg, rgba(243, 239, 230, 0.07) 0 1px, transparent 1px 30px);
		mix-blend-mode: screen;
	}

	.scan-line {
		position: absolute;
		left: 0;
		right: 0;
		top: 28%;
		height: 2px;
		background: var(--cream);
		box-shadow: 0 0 22px rgba(243, 239, 230, 0.48);
		animation: hero-scan 4.8s ease-in-out infinite;
		z-index: 2;
	}

	.topo-line {
		position: absolute;
		border: 2px solid rgba(243, 239, 230, 0.66);
		border-radius: 48% 52% 46% 54%;
		transform: rotate(-14deg);
		z-index: 1;
	}

	.line-one {
		width: 72%;
		height: 48%;
		left: 11%;
		top: 16%;
	}

	.line-two {
		width: 56%;
		height: 34%;
		left: 21%;
		top: 24%;
		border-color: rgba(243, 239, 230, 0.5);
	}

	.line-three {
		width: 86%;
		height: 54%;
		left: 6%;
		top: 38%;
		border-color: rgba(159, 104, 73, 0.76);
	}

	.line-four {
		width: 48%;
		height: 28%;
		left: 39%;
		top: 48%;
		border-color: rgba(243, 239, 230, 0.46);
	}

	.panel-footer {
		position: absolute;
		left: 22px;
		right: 22px;
		bottom: 22px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 14px;
		border-top: 1px solid rgba(243, 239, 230, 0.34);
		color: var(--cream);
		font-family: "Roboto Slab", serif;
		font-size: 13px;
		z-index: 3;
	}

	@keyframes hero-scan {
		0%, 100% {
			transform: translateY(-54px);
			opacity: 0.5;
		}
		50% {
			transform: translateY(194px);
			opacity: 1;
		}
	}

	.about-section {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		background:
			linear-gradient(180deg, rgba(246, 247, 243, 1), rgba(243, 239, 230, 0.86)),
			repeating-linear-gradient(0deg, rgba(35, 31, 32, 0.045) 0 1px, transparent 1px 72px),
			repeating-linear-gradient(90deg, rgba(35, 31, 32, 0.035) 0 1px, transparent 1px 72px),
			var(--paper);
		border-bottom: 2px solid var(--ink);
	}

	.about-section::before {
		content: '';
		position: absolute;
		width: min(54vw, 620px);
		height: min(54vw, 620px);
		left: -24vw;
		top: 12%;
		border: 1px solid rgba(159, 104, 73, 0.28);
		border-radius: 50%;
		box-shadow:
			inset 0 0 0 38px rgba(159, 104, 73, 0.035),
			inset 0 0 0 104px rgba(58, 87, 54, 0.035);
		pointer-events: none;
		z-index: -1;
	}

	.body-section.about {
		position: relative;
		padding-top: clamp(72px, 9vw, 126px);
		padding-bottom: clamp(72px, 9vw, 126px);
	}

	.body-section.about::after {
		content: '';
		position: absolute;
		right: 50px;
		top: clamp(48px, 7vw, 86px);
		width: min(36vw, 460px);
		height: 2px;
		background: linear-gradient(90deg, transparent, rgba(159, 104, 73, 0.72), var(--moss));
	}

	.about-copy {
		max-width: 980px;
		margin-bottom: clamp(34px, 5vw, 64px);
	}

	.about-copy .section-kicker {
		margin-bottom: 18px;
	}

	.about-text {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.62fr);
		gap: clamp(22px, 4vw, 56px);
		align-items: end;
	}

	.about-text p {
		color: rgba(35, 31, 32, 0.78);
		font-size: clamp(18px, 2vw, 26px);
		font-weight: 300;
		line-height: 1.35;
		margin-bottom: 0;
	}

	.about-text p:first-child {
		color: var(--ink);
		font-family: "Fraunces", serif;
		font-size: clamp(34px, 5.7vw, 76px);
		line-height: 0.98;
	}

	.about-text p.emphasis {
		color: var(--moss);
		font-size: clamp(20px, 2.4vw, 32px);
		text-decoration-line: underline;
		text-decoration-color: var(--clay);
		text-decoration-thickness: 2px;
		text-underline-offset: 7px;
	}

	.about-carousel-shell {
		position: relative;
		background: var(--ink);
		border: 2px solid var(--ink);
		box-shadow: 18px 18px 0 rgba(35, 31, 32, 0.1);
	}

	.about-carousel-shell::before {
		content: '';
		position: absolute;
		inset: 20px;
		border: 1px solid rgba(243, 239, 230, 0.44);
		pointer-events: none;
		z-index: 2;
	}

	.about-carousel-shell .carousel {
		position: relative;
		overflow: hidden;
	}

	.about-carousel-shell .carousel-image {
		aspect-ratio: 16 / 9;
		background: var(--ink);
	}

	.about-carousel-shell .carousel-image img {
		width: 100%;
		height: 100%;
		display: block;
		object-fit: cover;
	}

	.about-carousel-shell .image-caption {
		position: absolute;
		left: 20px;
		bottom: 20px;
		max-width: calc(100% - 40px);
		margin: 0;
		padding: 8px 10px;
		color: var(--cream);
		background: rgba(35, 31, 32, 0.72);
		border: 1px solid rgba(243, 239, 230, 0.28);
		font-size: 13px;
		z-index: 3;
	}

	.body-section-text {
		padding: 25px;
	}

	.body-section-text.border {
		border: solid 2px #2f2f2b;
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: flex-start;
		text-align: left;
		background-color: #f3eeee;
	}

	.body-section-text.border.eighty {
		margin: auto;
		width: 80%;
		margin-bottom: 50px;
	}

	.body-section-text.border.fifty {
		width: 50%;
	}

	.body-section-text p {
		color: #2f2f2b;
	}

	.body-section-text p.emphasis {
		font-size: 1.12em;
		text-decoration-line: underline;
		text-decoration-color: #3A5736;
		text-decoration-thickness: 2px;
		text-underline-offset: 5px;
	}

	.body-section-title {
		width: 50%;
	}

	.body-section-title h2 {
		color: #2f2f2b;
		white-space: nowrap;
		padding-bottom: 20px;
		border-bottom: 4px solid #3A5736;
		margin-bottom: 20px;
	}

	.body-section-title.center {
		margin: auto;
		width: 80%;
	}

	.body-section-title.center h2 {
		text-align: center
	}

	.body-section-image {
		max-width: 210px;
    width: 100%;
    margin: 0 auto;
	}

	.body-section-image.mobile {
		display: none;
	}

	.carousel {
		position: relative;
	}

	.carousel-image img {
		display: block;
		width: 100%;
	}

	.carousel-control {
		position: absolute;
		top: 0;
		bottom: 0;
		width: 20%;
		border: none;
		background: transparent;
		cursor: pointer;
		z-index: 2;

		display: flex;
		align-items: center;
		font-size: 3rem;
		color: white;
	}

	.carousel-control.prev {
		left: 0;
		justify-content: flex-start;
		padding-left: 6rem;
	}

	.carousel-control.next {
		right: 0;
		justify-content: flex-end;
		padding-right: 6rem;
	}

	.image-caption {
		text-align: center;
    margin-top: 5px;
		font-size: 16px;
	}

	.contact-section {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		padding: clamp(72px, 9vw, 126px) 50px;
		background:
			linear-gradient(135deg, rgba(35, 31, 32, 0.98), rgba(58, 87, 54, 0.93)),
			repeating-linear-gradient(0deg, rgba(243, 239, 230, 0.07) 0 1px, transparent 1px 72px),
			repeating-linear-gradient(90deg, rgba(243, 239, 230, 0.055) 0 1px, transparent 1px 72px),
			var(--ink);
		border-bottom: 2px solid var(--ink);
	}

